<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ArtDeq.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ArtDeq.Views"
    Shell.NavBarIsVisible="False"
    Shell.TabBarIsVisible="False">

    <TabBar>
        <Tab Title="Home">
            <ShellContent Route="feed"
                          ContentTemplate="{DataTemplate views:FeedPage}" />
        </Tab>
        <Tab Title="Explore">
            <ShellContent Route="explore"
                          ContentTemplate="{DataTemplate views:PlaceholderPage}" />
        </Tab>
        <Tab Title=" + ">
            <ShellContent Route="add"
                          ContentTemplate="{DataTemplate views:PlaceholderPage}" />
        </Tab>
        <Tab Title="Activity">
            <ShellContent Route="activity"
                          ContentTemplate="{DataTemplate views:PlaceholderPage}" />
        </Tab>
        <Tab Title="Profile">
            <ShellContent Route="profile"
                          ContentTemplate="{DataTemplate views:PlaceholderPage}" />
        </Tab>
    </TabBar>

</Shell>
